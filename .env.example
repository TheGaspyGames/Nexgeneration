# ============================
# NEXGENERATION BOT - Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================

# --- Requeridas ---

# Token del bot de Discord (obtenido en https://discord.com/developers/applications)
TOKEN=

# ID de la aplicación de Discord (Client ID)
CLIENT_ID=

# ID del servidor principal donde opera el bot
GUILD_ID=

# --- Base de datos ---

# URI de conexión a MongoDB (opcional, si no se configura se usa almacenamiento en archivos)
MONGODB_URI=

# --- Uptime ---

# URL para el heartbeat de uptime (opcional, ej: UptimeRobot, BetterUptime)
UPTIME=

# --- Configuración de comandos ---

# Si es true, no registra comandos globales (solo para desarrollo)
SKIP_GLOBAL_COMMANDS=false

# Si es true, despliega comandos solo en el servidor de GUILD_ID (más rápido para pruebas)
DEPLOY_GUILD_COMMANDS=false

# --- Logging ---

# Nivel mínimo de logs en consola: DEBUG | INFO | WARN | ERROR
# Por defecto: INFO en producción, DEBUG en desarrollo
LOG_LEVEL=INFO

# --- Entorno ---

# NODE_ENV: development | production
NODE_ENV=production
